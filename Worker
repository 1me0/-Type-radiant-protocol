[package]
name = "radiant-worker"
version = "0.1.0"
edition = "2021"

[dependencies]
rdkafka = { version = "0.36", features = ["tokio"] }
tokio = { version = "1", features = ["full"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
nova = { git = "https://github.com/microsoft/Nova", features = ["parallel"] }
bellperson = "0.24"
ff = "0.13"
rand = "0.8"
