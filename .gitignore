# ============================================================
# Radiant Protocol – .gitignore
# ============================================================
# This file tells Git which files and directories to ignore.
# It covers dependencies, build outputs, environment files,
# IDE artifacts, and operating system clutter.
# ============================================================

# ------------------------------------------------------------
# Environment & Secrets
# ------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.development
*.pem
*.key
*.priv
*.secret

# ------------------------------------------------------------
# Node.js / JavaScript / TypeScript
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json   # optional – commit if you use exact versions
yarn.lock           # optional
pnpm-lock.yaml      # optional
dist/
build/
.next/
out/
coverage/
*.log

# ------------------------------------------------------------
# Hardhat / Solidity (Smart Contracts)
# ------------------------------------------------------------
artifacts/
cache/
typechain-types/
coverage.json
gas-report.txt
deployments/localhost/
deployments/*/solcInputs/
.flattened/

# ------------------------------------------------------------
# Rust (Worker / Prover)
# ------------------------------------------------------------
target/
**/target/
Cargo.lock   # keep for binaries; remove for libraries (optional)
*.rs.bk
*.rlib

# ------------------------------------------------------------
# Python (Backend / AI)
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
env/
.venv/
*.egg-info/
*.egg
.python-version

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
docker-compose.override.yml
*.dockerignore
*.pid
.docker/

# ------------------------------------------------------------
# IDEs & Editors
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ------------------------------------------------------------
# OS generated files
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.tmp

# ------------------------------------------------------------
# Misc (logs, temporary files)
# ------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.swp
