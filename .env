# ============================================================
# Radiant Protocol – Environment Variables Template
# ============================================================
# Copy this file to `.env` and fill in your own values.
# Never commit `.env` to version control.
# ============================================================

# ------------------------------------------------------------
# Smart Contract Deployment (Hardhat / Foundry)
# ------------------------------------------------------------
# Sepolia testnet RPC URL (e.g., from Infura, Alchemy, or a local node)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Deployer wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ------------------------------------------------------------
# Frontend – Contract Addresses
# ------------------------------------------------------------
# Main Radiant contract address (after deployment)
CONTRACT_ADDRESS=0xYourRadiantContractAddress

# Same address exposed to React frontend (must start with REACT_APP_)
REACT_APP_CONTRACT_ADDRESS=0xYourRadiantContractAddress

# ------------------------------------------------------------
# Frontend – Services (WebSocket & API)
# ------------------------------------------------------------
# WebSocket server URL for real‑time updates (e.g., from Relayer)
REACT_APP_WS_URL=wss://your-websocket-server.com

# Backend API URL (e.g., FastAPI server)
REACT_APP_API_URL=https://your-api-server.com

# ------------------------------------------------------------
# Optional: Other networks (add as needed)
# ------------------------------------------------------------
# MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# OPTIMISM_RPC_URL=https://mainnet.optimism.io

# ------------------------------------------------------------
# Optional: Local development (Ganache / Hardhat node)
# ------------------------------------------------------------
# GANACHE_RPC_URL=http://localhost:8545
# LOCAL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
