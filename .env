# ============================================================
# Radiant Protocol – Environment Variables Template
# ============================================================
# Copy this file to `.env` and fill in your own values.
# Never commit `.env` to version control.
# ============================================================

# ------------------------------------------------------------
# Smart Contract Deployment (Hardhat / Foundry)
# ------------------------------------------------------------
# Choose ONE network below by uncommenting the corresponding RPC URL.
# Default: Sepolia testnet

# Sepolia testnet (recommended for development)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Arbitrum One / Nova (mainnet or testnet)
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# ARBITRUM_NOVA_RPC_URL=https://nova.arbitrum.io/rpc

# Ethereum Mainnet
# MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# Local development (Ganache / Hardhat node)
# LOCAL_RPC_URL=http://localhost:8545

# Deployer wallet private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# API key for contract verification (Etherscan, Arbiscan, etc.)
VERIFIER_API_KEY=your_verifier_api_key_here
# For Sepolia: Etherscan API key
# For Arbitrum: Arbiscan API key

# ------------------------------------------------------------
# Frontend – Contract Addresses
# ------------------------------------------------------------
# Update these after deployment with the actual contract addresses.

# Main Radiant contract address
CONTRACT_ADDRESS=0xYourRadiantContractAddress

# Same address exposed to React frontend (must start with VITE_ or REACT_APP_)
VITE_CONTRACT_ADDRESS=0xYourRadiantContractAddress

# Registry contract address (for dynamic discovery)
VITE_REGISTRY_ADDRESS=0xYourRegistryContractAddress

# ------------------------------------------------------------
# Frontend – Services (WebSocket & API)
# ------------------------------------------------------------
# WebSocket server URL for real‑time updates
VITE_WS_URL=wss://your-websocket-server.com

# Backend API URL (FastAPI or similar)
VITE_API_URL=https://your-api-server.com

# ------------------------------------------------------------
# Optional: IPFS Pinning (for social demo)
# ------------------------------------------------------------
# Pinata JWT token (obtain from https://pinata.cloud)
# PINATA_JWT=your_pinata_jwt_here

# ------------------------------------------------------------
# Optional: Local development wallet (Hardhat default)
# ------------------------------------------------------------
# LOCAL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
